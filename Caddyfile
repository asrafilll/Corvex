{$PLATFORM_SITE_ADDRESS:http://localhost} {
	encode zstd gzip

	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
	}

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	root * /srv/platform
	try_files {path} /index.html
	file_server
}

{$ADMIN_SITE_ADDRESS:http://admin.localhost} {
	encode zstd gzip

	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
	}

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	root * /srv/admin
	try_files {path} /index.html
	file_server
}

{$API_SITE_ADDRESS:http://api.localhost} {
	encode zstd gzip

	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
	}

	reverse_proxy api:8000
}
